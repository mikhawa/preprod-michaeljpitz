{% extends 'base.html.twig' %}

{% block title %}Vérification en deux étapes{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto mt-16">
        <h1 class="text-2xl font-bold text-center mb-4">Vérification en deux étapes</h1>
        <p class="text-center text-[var(--text-secondary)] mb-8">
            Un code à 6 chiffres vous a été envoyé par email. Il est valable 10 minutes.
        </p>

        {% for message in app.flashes('error') %}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                {{ message }}
            </div>
        {% endfor %}

        {{ form_start(form, {attr: {class: 'bg-[var(--bg-secondary)] p-8 rounded-lg border border-[var(--border)]', 'data-turbo': 'false'}}) }}
            <div class="mb-6">
                {{ form_label(form.code, null, {label_attr: {class: 'block text-sm font-medium text-[var(--text-secondary)] mb-1'}}) }}
                {{ form_widget(form.code, {attr: {class: 'w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent)] text-center text-2xl tracking-widest', autofocus: 'autofocus'}}) }}
                {{ form_errors(form.code) }}
            </div>

            <button type="submit"
                    class="w-full bg-[var(--accent)] text-white py-2 px-4 rounded-lg hover:bg-[var(--accent-hover)] transition-colors font-medium">
                Vérifier le code
            </button>
        {{ form_end(form) }}

        <p class="text-center mt-4 text-sm text-[var(--text-secondary)]">
            <a href="{{ path('app_logout') }}" class="text-[var(--accent)] hover:text-[var(--accent-hover)]">
                Annuler et se déconnecter
            </a>
        </p>
    </div>
{% endblock %}
