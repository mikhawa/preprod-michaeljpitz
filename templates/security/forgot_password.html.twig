{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto mt-16">
        <h1 class="text-2xl font-bold text-center mb-8">Mot de passe oublié</h1>

        <p class="text-sm text-[var(--text-secondary)] text-center mb-6">
            Saisissez votre adresse email. Si un compte existe, vous recevrez un lien de réinitialisation.
        </p>

        {{ form_start(form, {'attr': {'class': 'bg-[var(--bg-secondary)] p-8 rounded-lg border border-[var(--border)]'}}) }}
            <div class="mb-6">
                {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-medium text-[var(--text-secondary)] mb-1'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent)]', 'autofocus': true}}) }}
                {{ form_errors(form.email, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
            </div>

            <button type="submit"
                    class="w-full bg-[var(--accent)] text-white py-2 px-4 rounded-lg hover:bg-[var(--accent-hover)] transition-colors font-medium">
                Envoyer le lien de réinitialisation
            </button>
        {{ form_end(form) }}

        <p class="text-center mt-4 text-sm text-[var(--text-secondary)]">
            <a href="{{ path('app_login') }}" class="text-[var(--accent)] hover:text-[var(--accent-hover)]">Retour à la connexion</a>
        </p>
    </div>
{% endblock %}
