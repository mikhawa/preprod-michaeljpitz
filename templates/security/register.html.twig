{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto mt-16">
        <h1 class="text-2xl font-bold text-center mb-8">Inscription</h1>

        {% for flash in app.flashes('success') %}
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
                {{ flash }}
            </div>
        {% endfor %}

        {{ form_start(registrationForm, {attr: {class: 'bg-[var(--bg-secondary)] p-8 rounded-lg border border-[var(--border)]', 'data-turbo': 'false'}}) }}
            <div class="mb-4">
                {{ form_label(registrationForm.email, null, {label_attr: {class: 'block text-sm font-medium text-[var(--text-secondary)] mb-1'}}) }}
                {{ form_widget(registrationForm.email, {attr: {class: 'w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent)]'}}) }}
                {{ form_errors(registrationForm.email) }}
            </div>

            <div class="mb-4">
                {{ form_label(registrationForm.userName, null, {label_attr: {class: 'block text-sm font-medium text-[var(--text-secondary)] mb-1'}}) }}
                {{ form_widget(registrationForm.userName, {attr: {class: 'w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent)]'}}) }}
                {{ form_errors(registrationForm.userName) }}
            </div>

            <div class="mb-4">
                {{ form_label(registrationForm.plainPassword.first, null, {label_attr: {class: 'block text-sm font-medium text-[var(--text-secondary)] mb-1'}}) }}
                {{ form_widget(registrationForm.plainPassword.first, {attr: {class: 'w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent)]'}}) }}
                {{ form_errors(registrationForm.plainPassword.first) }}
            </div>

            <div class="mb-6">
                {{ form_label(registrationForm.plainPassword.second, null, {label_attr: {class: 'block text-sm font-medium text-[var(--text-secondary)] mb-1'}}) }}
                {{ form_widget(registrationForm.plainPassword.second, {attr: {class: 'w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent)]'}}) }}
                {{ form_errors(registrationForm.plainPassword) }}
            </div>

            {% if turnstileSiteKey is defined and turnstileSiteKey and turnstileSiteKey != 'YOUR_TURNSTILE_SITE_KEY' and not (turnstileSiteKey starts with '1x00000000000000000000') %}
            <div class="flex justify-center mb-6">
                <div class="cf-turnstile" data-sitekey="{{ turnstileSiteKey }}" data-theme="auto"></div>
            </div>
            {% endif %}

            <button type="submit"
                    class="w-full bg-[var(--accent)] text-white py-2 px-4 rounded-lg hover:bg-[var(--accent-hover)] transition-colors font-medium">
                S'inscrire
            </button>
        {{ form_end(registrationForm) }}

        <p class="text-center mt-4 text-sm text-[var(--text-secondary)]">
            Déjà inscrit ?
            <a href="{{ path('app_login') }}" class="text-[var(--accent)] hover:text-[var(--accent-hover)]">Se connecter</a>
        </p>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if turnstileSiteKey is defined and turnstileSiteKey and turnstileSiteKey != 'YOUR_TURNSTILE_SITE_KEY' and not (turnstileSiteKey starts with '1x00000000000000000000') %}
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    {% endif %}
{% endblock %}
