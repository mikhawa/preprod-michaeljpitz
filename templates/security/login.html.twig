{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto mt-16">
        <h1 class="text-2xl font-bold text-center mb-8">Connexion</h1>

        {% if error %}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" class="bg-[var(--bg-secondary)] p-8 rounded-lg border border-[var(--border)]" data-turbo="false">
            <div class="mb-4">
                <label for="username" class="block text-sm font-medium text-[var(--text-secondary)] mb-1">Email</label>
                <input type="email" value="{{ last_username }}" name="_username" id="username" autocomplete="email" required autofocus
                       class="w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent)]">
            </div>

            <div class="mb-6">
                <label for="password" class="block text-sm font-medium text-[var(--text-secondary)] mb-1">Mot de passe</label>
                <input type="password" name="_password" id="password" autocomplete="current-password" required
                       class="w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent)]">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            {% if turnstileSiteKey is defined and turnstileSiteKey and turnstileSiteKey != 'YOUR_TURNSTILE_SITE_KEY' and not (turnstileSiteKey starts with '1x00000000000000000000') %}
            <div class="flex justify-center mb-6">
                <div class="cf-turnstile" data-sitekey="{{ turnstileSiteKey }}" data-theme="auto"></div>
            </div>
            {% endif %}

            <div class="flex items-center justify-between mb-6">
                <label class="flex items-center gap-2 text-sm text-[var(--text-secondary)]">
                    <input type="checkbox" name="_remember_me" class="rounded">
                    Se souvenir de moi
                </label>
                <a href="{{ path('app_forgot_password') }}" class="text-sm text-[var(--accent)] hover:text-[var(--accent-hover)]">Mot de passe oublié ?</a>
            </div>

            <button type="submit"
                    class="w-full bg-[var(--accent)] text-white py-2 px-4 rounded-lg hover:bg-[var(--accent-hover)] transition-colors font-medium">
                Se connecter
            </button>
        </form>

        <p class="text-center mt-4 text-sm text-[var(--text-secondary)]">
            Pas encore inscrit ?
            <a href="{{ path('app_register') }}" class="text-[var(--accent)] hover:text-[var(--accent-hover)]">Créer un compte</a>
        </p>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if turnstileSiteKey is defined and turnstileSiteKey and turnstileSiteKey != 'YOUR_TURNSTILE_SITE_KEY' and not (turnstileSiteKey starts with '1x00000000000000000000') %}
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    {% endif %}
{% endblock %}
