{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto mt-16">
        <h1 class="text-2xl font-bold text-center mb-8">Nouveau mot de passe</h1>

        {{ form_start(form, {'attr': {'class': 'bg-[var(--bg-secondary)] p-8 rounded-lg border border-[var(--border)]'}}) }}
            <div class="mb-4">
                {{ form_label(form.plainPassword.first, null, {'label_attr': {'class': 'block text-sm font-medium text-[var(--text-secondary)] mb-1'}}) }}
                {{ form_widget(form.plainPassword.first, {'attr': {'class': 'w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent)]', 'autofocus': true}}) }}
                {{ form_errors(form.plainPassword.first, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
            </div>

            <div class="mb-6">
                {{ form_label(form.plainPassword.second, null, {'label_attr': {'class': 'block text-sm font-medium text-[var(--text-secondary)] mb-1'}}) }}
                {{ form_widget(form.plainPassword.second, {'attr': {'class': 'w-full px-3 py-2 rounded-lg border border-[var(--border)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent)]'}}) }}
                {{ form_errors(form.plainPassword.second, {'attr': {'class': 'text-red-500 text-sm mt-1'}}) }}
            </div>

            {{ form_errors(form.plainPassword, {'attr': {'class': 'text-red-500 text-sm mb-4'}}) }}

            <button type="submit"
                    class="w-full bg-[var(--accent)] text-white py-2 px-4 rounded-lg hover:bg-[var(--accent-hover)] transition-colors font-medium">
                Réinitialiser le mot de passe
            </button>
        {{ form_end(form) }}
    </div>
{% endblock %}
