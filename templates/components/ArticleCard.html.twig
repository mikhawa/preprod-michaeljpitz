{# @var article \App\Entity\Article #}
{% props article %}

<article class="bg-[var(--bg-secondary)] rounded-lg overflow-hidden border border-[var(--border)] hover:shadow-lg transition-shadow">
    {% if article.featuredImage %}
        <a href="{{ path('app_article_show', {slug: article.slug}) }}">
            <img src="{{ '/uploads/articles/' ~ article.featuredImage }}"
                 alt="{{ article.title }}"
                 class="w-full h-48 object-cover">
        </a>
    {% else %}
        <a href="{{ path('app_article_show', {slug: article.slug}) }}"
           class="block w-full h-48 bg-[var(--border)] flex items-center justify-center">
            <span class="text-[var(--text-secondary)] text-4xl">&#128221;</span>
        </a>
    {% endif %}

    <div class="p-5">
        {% if article.categories is not empty %}
            <div class="flex flex-wrap gap-1">
                {% for category in article.categories %}
                    <twig:CategoryBadge :category="category" />
                {% endfor %}
            </div>
        {% endif %}

        <h3 class="text-lg font-semibold mt-2 mb-2">
            <a href="{{ path('app_article_show', {slug: article.slug}) }}"
               class="text-[var(--text-primary)] hover:text-[var(--accent)]">
                {{ article.title }}
            </a>
        </h3>

        {% if article.excerpt %}
            <p class="text-[var(--text-secondary)] text-sm mb-3 line-clamp-3">
                {{ article.excerpt }}
            </p>
        {% endif %}

        <div class="flex items-center justify-between text-xs text-[var(--text-secondary)]">
            <time datetime="{{ article.publishedAt ? article.publishedAt|date('Y-m-d') : article.createdAt|date('Y-m-d') }}">
                {{ article.publishedAt ? article.publishedAt|date('d/m/Y') : article.createdAt|date('d/m/Y') }}
            </time>
            <a href="{{ path('app_article_show', {slug: article.slug}) }}"
               class="text-[var(--accent)] hover:text-[var(--accent-hover)] font-medium">
                Lire &rarr;
            </a>
        </div>
    </div>
</article>
