<header class="border-b border-[var(--border)]" data-controller="navbar">
    <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        {# Logo #}
        <a href="{{ path('app_home') }}" class="text-xl font-bold text-[var(--accent)] hover:text-[var(--accent-hover)]">
            Michaël J. Pitz
        </a>

        {# Desktop nav #}
        <div class="hidden md:flex items-center gap-6">
            <a href="{{ path('app_home') }}" class="flex items-center gap-2 text-[var(--text-secondary)] hover:text-[var(--text-primary)]">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
                Accueil
            </a>
            <a href="{{ path('app_cv') }}" class="flex items-center gap-2 text-[var(--text-secondary)] hover:text-[var(--text-primary)]">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                CV
            </a>
            <a href="{{ path('app_article_index') }}" class="flex items-center gap-2 text-[var(--text-secondary)] hover:text-[var(--text-primary)]">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v8a2 2 0 01-2 2zM9 13h6M9 17h4"/>
                </svg>
                Articles
            </a>

            {# Catégories avec sous-menus #}
            {% set tree = this.categoryTree %}
            {% if tree is not empty %}
                <span class="text-[var(--border)]">|</span>
                {% for node in tree %}
                    <div class="relative"
                         data-navbar-target="dropdownContainer"
                         data-action="mouseenter->navbar#showDropdown mouseleave->navbar#scheduleHideDropdown">
                        <a href="{{ path('app_category_show', {slug: node.category.slug}) }}"
                           class="text-[var(--text-secondary)] hover:text-[var(--text-primary)] inline-flex items-center gap-1">
                            {{ node.category.title }}
                            {% if node.children is not empty %}
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                </svg>
                            {% endif %}
                        </a>
                        {% if node.children is not empty %}
                            <div class="absolute left-0 top-full pt-1 hidden z-50"
                                 data-navbar-target="dropdown">
                                <div class="bg-[var(--bg-secondary)] border border-[var(--border)] rounded-lg shadow-lg py-1 min-w-[180px]">
                                    {% for child in node.children %}
                                        <div class="relative"
                                             data-navbar-target="submenuContainer"
                                             data-action="mouseenter->navbar#showSubmenu mouseleave->navbar#scheduleHideSubmenu">
                                            <a href="{{ path('app_category_show', {slug: child.category.slug}) }}"
                                               class="block px-4 py-2 text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-primary)] inline-flex items-center justify-between w-full">
                                                {{ child.category.title }}
                                                {% if child.children is not empty %}
                                                    <svg class="w-3 h-3 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                                    </svg>
                                                {% endif %}
                                            </a>
                                            {% if child.children is not empty %}
                                                <div class="absolute left-full top-0 pl-1 hidden z-50"
                                                     data-navbar-target="submenu">
                                                    <div class="bg-[var(--bg-secondary)] border border-[var(--border)] rounded-lg shadow-lg py-1 min-w-[160px]">
                                                        {% for subchild in child.children %}
                                                            <a href="{{ path('app_category_show', {slug: subchild.category.slug}) }}"
                                                               class="block px-4 py-2 text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-primary)]">
                                                                {{ subchild.category.title }}
                                                            </a>
                                                        {% endfor %}
                                                    </div>
                                                </div>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            {% endif %}

            <a href="{{ path('app_contact') }}" class="flex items-center gap-2 text-[var(--text-secondary)] hover:text-[var(--text-primary)]">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                Contact
            </a>

            {% if app.user %}
                <div class="relative"
                     data-navbar-target="userDropdownContainer"
                     data-action="mouseenter->navbar#showUserDropdown mouseleave->navbar#scheduleHideUserDropdown">
                    <button class="flex items-center gap-2 text-[var(--text-secondary)] hover:text-[var(--text-primary)]">
                        {% if app.user.avatarName %}
                            <img src="{{ '/uploads/avatars/' ~ app.user.avatarName }}"
                                 alt=""
                                 class="w-6 h-6 rounded-full object-cover">
                        {% endif %}
                        {{ app.user.userName }}
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div class="absolute right-0 top-full pt-1 hidden z-50"
                         data-navbar-target="userDropdown">
                        <div class="bg-[var(--bg-secondary)] border border-[var(--border)] rounded-lg shadow-lg py-1 min-w-[160px]">
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('admin') }}"
                                   class="flex items-center gap-2 px-4 py-2 text-sm text-[var(--accent)] hover:text-[var(--accent-hover)] hover:bg-[var(--bg-primary)] font-medium border-b border-[var(--border)]">
                                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    </svg>
                                    Administration
                                </a>
                            {% endif %}
                            <a href="{{ path('app_profile') }}"
                               class="flex items-center gap-2 px-4 py-2 text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-primary)]">
                                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                </svg>
                                Profil
                            </a>
                            <a href="{{ path('app_logout') }}"
                               class="flex items-center gap-2 px-4 py-2 text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-primary)]">
                                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                                </svg>
                                Déconnexion
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                <a href="{{ path('app_login') }}" class="flex items-center gap-2 text-[var(--text-secondary)] hover:text-[var(--text-primary)]">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
                    </svg>
                    Connexion
                </a>
                <a href="{{ path('app_register') }}" class="flex items-center gap-2 text-[var(--accent)] hover:text-[var(--accent-hover)] font-medium">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                    </svg>
                    Inscription
                </a>
            {% endif %}
            <button data-action="click->theme#toggle"
                    data-theme-target="toggle"
                    class="p-2 rounded-lg bg-[var(--bg-secondary)] hover:bg-[var(--border)] transition-colors"
                    aria-label="Basculer le thème">
            </button>
        </div>

        {# Mobile: hamburger + theme toggle #}
        <div class="flex md:hidden items-center gap-2">
            <button data-action="click->theme#toggle"
                    data-theme-target="toggle"
                    class="p-2 rounded-lg bg-[var(--bg-secondary)] hover:bg-[var(--border)] transition-colors"
                    aria-label="Basculer le thème">
            </button>
            <button data-action="click->navbar#toggleMobile"
                    class="p-2 rounded-lg bg-[var(--bg-secondary)] hover:bg-[var(--border)] transition-colors"
                    aria-label="Menu">
                <svg data-navbar-target="hamburgerIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
                <svg data-navbar-target="closeIcon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
    </nav>

    {# Mobile menu #}
    <div class="hidden md:hidden border-t border-[var(--border)]" data-navbar-target="mobileMenu">
        <div class="px-4 py-4 space-y-3">
            <a href="{{ path('app_home') }}" class="block text-[var(--text-secondary)] hover:text-[var(--text-primary)]">Accueil</a>
            <a href="{{ path('app_home') }}#cv" class="block text-[var(--text-secondary)] hover:text-[var(--text-primary)]">CV</a>
            <a href="{{ path('app_article_index') }}" class="block text-[var(--text-secondary)] hover:text-[var(--text-primary)]">Articles</a>

            {# Catégories mobile (accordéon) #}
            {% if tree is defined and tree is not empty %}
                <div class="border-t border-[var(--border)] pt-3">
                    <span class="block text-xs font-semibold text-[var(--text-secondary)] uppercase tracking-wider mb-2">Catégories</span>
                    {% for node in tree %}
                        <div class="mb-1">
                            <div class="flex items-center justify-between">
                                <a href="{{ path('app_category_show', {slug: node.category.slug}) }}"
                                   class="block py-1 text-[var(--text-secondary)] hover:text-[var(--text-primary)]">
                                    {{ node.category.title }}
                                </a>
                                {% if node.children is not empty %}
                                    <button data-action="click->navbar#toggleAccordion"
                                            class="p-1 text-[var(--text-secondary)] hover:text-[var(--text-primary)]"
                                            aria-label="Déplier">
                                        <svg class="w-4 h-4 transition-transform" data-navbar-target="accordionIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                        </svg>
                                    </button>
                                {% endif %}
                            </div>
                            {% if node.children is not empty %}
                                <div class="hidden pl-4" data-navbar-target="accordionPanel">
                                    {% for child in node.children %}
                                        <a href="{{ path('app_category_show', {slug: child.category.slug}) }}"
                                           class="block py-1 text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)]">
                                            {{ child.category.title }}
                                        </a>
                                        {% if child.children is not empty %}
                                            <div class="pl-4">
                                                {% for subchild in child.children %}
                                                    <a href="{{ path('app_category_show', {slug: subchild.category.slug}) }}"
                                                       class="block py-1 text-xs text-[var(--text-secondary)] hover:text-[var(--text-primary)]">
                                                        {{ subchild.category.title }}
                                                    </a>
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            <div class="border-t border-[var(--border)] pt-3">
                <a href="{{ path('app_home') }}#contact" class="block text-[var(--text-secondary)] hover:text-[var(--text-primary)]">Contact</a>
            </div>

            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin') }}" class="block text-[var(--accent)] hover:text-[var(--accent-hover)] font-medium">Administration</a>
            {% endif %}

            <div class="border-t border-[var(--border)] pt-3">
                {% if app.user %}
                    <div class="flex items-center gap-2 mb-2">
                        {% if app.user.avatarName %}
                            <img src="{{ '/uploads/avatars/' ~ app.user.avatarName }}"
                                 alt=""
                                 class="w-6 h-6 rounded-full object-cover">
                        {% endif %}
                        <span class="text-sm text-[var(--text-secondary)]">{{ app.user.userName }}</span>
                    </div>
                    <a href="{{ path('app_profile') }}" class="block text-[var(--text-secondary)] hover:text-[var(--text-primary)] mb-2">Profil</a>
                    <a href="{{ path('app_logout') }}" class="block text-[var(--text-secondary)] hover:text-[var(--text-primary)]">Déconnexion</a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="block text-[var(--text-secondary)] hover:text-[var(--text-primary)] mb-2">Connexion</a>
                    <a href="{{ path('app_register') }}" class="block text-[var(--accent)] hover:text-[var(--accent-hover)] font-medium">Inscription</a>
                {% endif %}
            </div>
        </div>
    </div>
</header>
