{# @var category \App\Entity\Category #}
{% props category, linked = true %}

{% if linked %}
    <a href="{{ path('app_category_show', {slug: category.slug}) }}"
       class="inline-block text-xs font-medium px-2.5 py-0.5 rounded-full"
       style="background-color: {{ category.color }}20; color: {{ category.color }}; border: 1px solid {{ category.color }}40;">
        {{ category.title }}
    </a>
{% else %}
    <span class="inline-block text-xs font-medium px-2.5 py-0.5 rounded-full"
          style="background-color: {{ category.color }}20; color: {{ category.color }}; border: 1px solid {{ category.color }}40;">
        {{ category.title }}
    </span>
{% endif %}
