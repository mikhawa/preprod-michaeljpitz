{% extends 'base.html.twig' %}

{% block title %}{{ page ? page.title : 'CV - Michaël J. Pitz' }}{% endblock %}
{% block meta_description %}Curriculum Vitae de Michaël J. Pitz, développeur PHP/Symfony.{% endblock %}

{% block body %}
    {% if page and page.content %}
        <article class="max-w-3xl mx-auto py-8">
            <h1 class="text-3xl font-bold mb-10 text-center">{{ page.title }}</h1>

            {% if page.featuredImage %}
                <figure class="mb-8">
                    <img src="{{ '/uploads/pages/' ~ page.featuredImage }}"
                         alt="{{ page.title }}"
                         class="w-full rounded-lg">
                </figure>
            {% endif %}

            <div class="prose prose-lg max-w-none
                        text-[var(--text-primary)]
                        [&_a]:text-[var(--accent)] [&_a]:hover:text-[var(--accent-hover)]
                        [&_h2]:text-[var(--text-primary)] [&_h3]:text-[var(--text-primary)]
                        [&_blockquote]:border-[var(--accent)] [&_blockquote]:text-[var(--text-secondary)]
                        [&_code]:bg-[var(--bg-secondary)] [&_code]:px-1 [&_code]:rounded
                        [&_pre]:bg-[var(--bg-secondary)] [&_pre]:border [&_pre]:border-[var(--border)]"
                 data-controller="external-link lightbox">
                {{ page.content|raw }}
            </div>
        </article>
    {% else %}
        <section class="py-12">
            <h1 class="text-3xl font-bold mb-10 text-center">Curriculum Vitae</h1>

            <div class="grid md:grid-cols-3 gap-8">
                {# Compétences #}
                <div class="bg-[var(--bg-secondary)] rounded-lg p-6 border border-[var(--border)]">
                    <h2 class="text-xl font-semibold mb-4 text-[var(--accent)]">Compétences</h2>
                    <ul class="space-y-2 text-[var(--text-secondary)]">
                        <li>PHP 8 / Symfony 7</li>
                        <li>Doctrine ORM / MySQL / MariaDB</li>
                        <li>HTML5 / CSS3 / Tailwind CSS</li>
                        <li>JavaScript / Stimulus</li>
                        <li>Docker / Git / CI-CD</li>
                        <li>API REST / Tests unitaires</li>
                    </ul>
                </div>

                {# Expériences #}
                <div class="bg-[var(--bg-secondary)] rounded-lg p-6 border border-[var(--border)]">
                    <h2 class="text-xl font-semibold mb-4 text-[var(--accent)]">Expériences</h2>
                    <div class="space-y-4">
                        <div>
                            <p class="font-medium">Développeur PHP/Symfony</p>
                            <p class="text-sm text-[var(--text-secondary)]">Entreprise XYZ - 2023-2026</p>
                            <p class="text-sm text-[var(--text-secondary)] mt-1">Développement d'applications web, API REST, intégration continue.</p>
                        </div>
                        <div>
                            <p class="font-medium">Développeur Web Junior</p>
                            <p class="text-sm text-[var(--text-secondary)]">Agence ABC - 2021-2023</p>
                            <p class="text-sm text-[var(--text-secondary)] mt-1">Création de sites WordPress et Symfony, maintenance applicative.</p>
                        </div>
                    </div>
                </div>

                {# Formations #}
                <div class="bg-[var(--bg-secondary)] rounded-lg p-6 border border-[var(--border)]">
                    <h2 class="text-xl font-semibold mb-4 text-[var(--accent)]">Formations</h2>
                    <div class="space-y-4">
                        <div>
                            <p class="font-medium">Licence Informatique</p>
                            <p class="text-sm text-[var(--text-secondary)]">Université - 2020</p>
                        </div>
                        <div>
                            <p class="font-medium">BTS SIO option SLAM</p>
                            <p class="text-sm text-[var(--text-secondary)]">Lycée - 2018</p>
                        </div>
                        <div>
                            <p class="font-medium">Certifications Symfony</p>
                            <p class="text-sm text-[var(--text-secondary)]">SymfonyCasts - 2022</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    {% endif %}
{% endblock %}
